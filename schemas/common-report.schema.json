{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaveep.dev/schemas/common-report.schema.json",
  "title": "CommonReport",
  "description": "Base report schema used by all KAVEEP modules for consistent cross-repository reporting.",
  "type": "object",
  "required": [
    "reportId",
    "sessionId",
    "generatedAt",
    "module",
    "moduleVersion",
    "status",
    "riskLevel",
    "evidenceRefs",
    "policyRefs",
    "auditRefs",
    "warnings",
    "errors",
    "metadata"
  ],
  "properties": {
    "reportId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "module": {
      "type": "string",
      "pattern": "^KAVEEP-[A-Z0-9-]+$"
    },
    "moduleVersion": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "COMPLETED",
        "PARTIAL",
        "FAILED",
        "CANCELLED",
        "UNVERIFIED",
        "NO_ACTION"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "NONE",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL",
        "UNKNOWN"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    },
    "policyRefs": {
      "type": "array",
      "items": {
        "$ref": "policy.schema.json"
      }
    },
    "auditRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "message": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "INFO",
            "WARNING",
            "ERROR",
            "CRITICAL"
          ]
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "$ref": "evidence.schema.json"
          }
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
